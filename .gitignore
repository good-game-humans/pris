# Ignore everything
/*

# Except these folders
!/code/
!/setup/
!/.gitignore

# Ignore macOS metadata
.DS_Store

# Ignore large/regeneratable files in setup
setup/local/*.qcow2
setup/local/arch-boot/
setup/local/*.log
setup/aws/arch-boot/

# Ignore build artifacts in code
code/**/node_modules/
code/**/.zig-cache/
code/**/zig-out/
code/**/dist/
